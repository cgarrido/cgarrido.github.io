---
import { en } from '../i18n/en';
import { es } from '../i18n/es';
---
<section id="hero" class="relative min-h-screen flex flex-col justify-center text-center px-4 sm:px-6 overflow-hidden pt-16">
  <!-- Dot grid background -->
  <div class="absolute inset-0 dot-grid opacity-30 pointer-events-none"></div>

  <!-- Indigo glow blob -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-accent opacity-10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-3xl w-full mx-auto">
    <!-- Profile photo -->
    <div class="mb-6 flex justify-center">
      <img
        src="/profile.jpg"
        alt="Cristian Garrido Méndez"
        width="120"
        height="120"
        class="rounded-full border-2 border-accent/40 shadow-lg shadow-accent/20 object-cover"
        style="width:120px;height:120px;"
      />
    </div>

    <p class="text-muted text-sm font-medium uppercase tracking-widest mb-4">
      <span class="lang-en">{en.hero.greeting}</span>
      <span class="lang-es">{es.hero.greeting}</span>
    </p>
    <h1 class="text-2xl sm:text-4xl md:text-6xl font-extrabold tracking-tight mb-4 bg-gradient-to-r from-white via-accent-light to-accent bg-clip-text text-transparent">
      {en.hero.name}
    </h1>
    <p class="text-accent-light text-base sm:text-lg md:text-xl font-semibold mb-6">
      <span class="lang-en">{en.hero.title}</span>
      <span class="lang-es">{es.hero.title}</span>
    </p>
    <p class="text-muted text-sm sm:text-base md:text-lg max-w-xl mx-auto mb-10">
      <span class="lang-en">{en.hero.tagline}</span>
      <span class="lang-es">{es.hero.tagline}</span>
    </p>

    <div class="flex flex-col sm:flex-row flex-wrap gap-3 items-center justify-center">
      <a href="#about" class="w-full sm:w-auto bg-accent hover:bg-accent-light text-white font-semibold px-6 py-3 rounded-lg transition-colors text-center">
        <span class="lang-en">{en.hero.cta}</span>
        <span class="lang-es">{es.hero.cta}</span>
      </a>
      <a href="https://github.com/cgarrido" target="_blank" rel="noopener" class="w-full sm:w-auto border border-border hover:border-accent text-muted hover:text-text px-6 py-3 rounded-lg transition-colors font-medium text-center">
        GitHub
      </a>
      <a href="https://www.linkedin.com/in/cristiangarridomendez/" target="_blank" rel="noopener" class="w-full sm:w-auto border border-border hover:border-accent text-muted hover:text-text px-6 py-3 rounded-lg transition-colors font-medium text-center">
        LinkedIn
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce text-muted">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
      <path d="M10 14l-6-6h12l-6 6z"/>
    </svg>
  </div>
</section>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, #6366f1 1px, transparent 1px);
    background-size: 32px 32px;
  }
</style>
