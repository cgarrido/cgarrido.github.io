---
import { en } from '../i18n/en';
import { es } from '../i18n/es';
---
<section id="contact" class="py-24">
  <div class="container text-center max-w-xl mx-auto">
    <h2 class="section-title animate-in inline-block">
      <span class="lang-en">{en.contact.title}</span>
      <span class="lang-es">{es.contact.title}</span>
    </h2>
    <p class="text-muted mb-10 animate-in">
      <span class="lang-en">{en.contact.subtitle}</span>
      <span class="lang-es">{es.contact.subtitle}</span>
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-in">
      <a href={`mailto:${en.contact.email}`}
         class="flex items-center gap-2 bg-surface border border-border hover:border-accent rounded-lg px-5 py-3 text-sm text-muted hover:text-text transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
        {en.contact.email}
      </a>
      <a href="https://www.linkedin.com/in/cristiangarridomendez/" target="_blank" rel="noopener"
         class="flex items-center gap-2 bg-surface border border-border hover:border-accent rounded-lg px-5 py-3 text-sm text-muted hover:text-text transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
        LinkedIn
      </a>
      <a href="https://github.com/cgarrido" target="_blank" rel="noopener"
         class="flex items-center gap-2 bg-surface border border-border hover:border-accent rounded-lg px-5 py-3 text-sm text-muted hover:text-text transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
        GitHub
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-border py-6 text-center text-muted text-xs">
  <p>Cristian Garrido Méndez · Zaragoza, Spain · {new Date().getFullYear()}</p>
</footer>
